---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import CtaCluster from '../components/CtaCluster.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { primaryCta, savingsPage, secondaryCta } from '../data/site';

const { hero, comparison, sprawl, proof, cta } = savingsPage;
---

<BaseLayout title={savingsPage.title} description={savingsPage.description} pageName={savingsPage.pageName}>
  <section class="hero hero--inner hero--savings">
    <div class="hero__grid">
      <div class="hero__copy">
        <p class="hero__eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="hero__lede">{hero.body}</p>
        <CtaCluster primary={primaryCta} secondary={secondaryCta} />
      </div>

      <div class="surface-card surface-card--contrast">
        <p class="surface-card__eyebrow">Why it matters</p>
        <h2>Fewer resets between tools means less wasted time.</h2>
        <p>When your core workflow stays together, staff spend less time restating the same details and families have a clearer path to follow.</p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionIntro title={comparison.title} body={comparison.body} align="center" />
    <div class="comparison-grid">
      <article class="comparison-card comparison-card--before">
        <p class="comparison-card__label">{comparison.beforeLabel}</p>
        <p>{comparison.beforeBody}</p>
      </article>
      <article class="comparison-card comparison-card--after">
        <p class="comparison-card__label">{comparison.afterLabel}</p>
        <p>{comparison.afterBody}</p>
      </article>
    </div>
  </section>

  <section class="content-section content-section--tint">
    <SectionIntro title={sprawl.title} body={sprawl.body} />
    <div class="matrix-grid">
      <article class="surface-card surface-card--warm">
        <p class="surface-card__eyebrow">{sprawl.leftTitle}</p>
        <ul class="surface-list">
          {sprawl.leftBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>

      <article class="surface-card surface-card--accent">
        <p class="surface-card__eyebrow">{sprawl.rightTitle}</p>
        <ul class="surface-list">
          {sprawl.rightBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="content-section content-section--contrast">
    <div class="split-panel split-panel--balanced">
      <SectionIntro eyebrow="Impact Story" title={proof.title} body={proof.body} />
      <p class="section-note section-note--contrast">{proof.note}</p>
    </div>
  </section>

  <CtaBanner eyebrow={cta.eyebrow} title={cta.title} body={cta.body} primary={primaryCta} secondary={secondaryCta} />
</BaseLayout>
