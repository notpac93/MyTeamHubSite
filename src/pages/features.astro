---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import CtaCluster from '../components/CtaCluster.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { featuresPage, primaryCta, secondaryCta } from '../data/site';

const { hero, indexLinks, sections, proof, cta } = featuresPage;
---

<BaseLayout title={featuresPage.title} description={featuresPage.description} pageName={featuresPage.pageName}>
  <section class="hero hero--inner">
    <div class="hero__grid hero__grid--single">
      <div class="hero__copy hero__copy--wide">
        <p class="hero__eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="hero__lede">{hero.body}</p>
        <CtaCluster primary={primaryCta} secondary={secondaryCta} />
      </div>
    </div>

    <nav class="section-index" aria-label="Feature sections">
      {indexLinks.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </section>

  <section class="content-section">
    <div class="feature-stack">
      {sections.map((section, index) => (
        <article id={section.id} class={`feature-block ${index % 2 === 1 ? 'feature-block--reverse' : ''}`}>
          <div>
            <SectionIntro eyebrow="Simple Workflow" title={section.title} body={section.body} />
          </div>

          <div class="surface-card surface-card--feature-detail">
            <p class="surface-card__eyebrow">Primary benefit</p>
            <h2>{section.benefit}</h2>

            <div class="feature-detail-grid">
              <div>
                <p class="feature-detail__label">{section.operatorTitle}</p>
                <ul class="surface-list">
                  {section.operatorItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>

              <div>
                <p class="feature-detail__label">{section.familyTitle}</p>
                <ul class="surface-list">
                  {section.familyItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section content-section--tint">
    <div class="split-panel split-panel--balanced">
      <SectionIntro eyebrow="Proof Block" title={proof.title} body={proof.body} />
      <div class="surface-card surface-card--accent">
        <p class="surface-card__eyebrow">What this page does</p>
        <h2>Show the task, the benefit, and the family outcome in one scan.</h2>
        <p>The page is designed so an operator can understand each workflow quickly without reading through generic marketing copy.</p>
      </div>
    </div>
  </section>

  <CtaBanner eyebrow={cta.eyebrow} title={cta.title} body={cta.body} primary={primaryCta} secondary={secondaryCta} />
</BaseLayout>
