---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import CtaCluster from '../components/CtaCluster.astro';
import ProgramBoard from '../components/ProgramBoard.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { homePage, primaryCta, secondaryCta } from '../data/site';

const { hero, heroPill, quickChecks, valueProps, workflows, proof, family, cta } = homePage;
---

<BaseLayout title={homePage.title} description={homePage.description} pageName={homePage.pageName}>
  <section class="hero hero--home">
    <div class="hero__grid">
      <div class="hero__copy">
        <div class="hero__pill" aria-label="Summary highlight">
          <span class="hero__pill-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation">
              <path d="M13 2 6 13h5l-1 9 8-12h-5l1-8Z" fill="currentColor"></path>
            </svg>
          </span>
          <span>{heroPill}</span>
        </div>
        <p class="hero__eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="hero__lede">{hero.body}</p>
        <CtaCluster primary={primaryCta} secondary={secondaryCta} />
      </div>

      <div class="hero__visual-stack">
        <ProgramBoard label="Illustrative operator view" title={proof.boardTitle} items={proof.boardItems} note={proof.note} />

        <div class="surface-card surface-card--accent">
          <p class="surface-card__eyebrow">What gets simpler</p>
          <h2>Publish once. Guide the next step. Keep updates in the same flow.</h2>
          <p>That structure gives staff fewer moving parts to manage and gives families fewer places to check.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="summary-strip" aria-label="Quick overview">
    <div class="summary-strip__inner">
      {quickChecks.map((item) => (
        <article class="summary-strip__item">
          <span class="summary-strip__check" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="presentation">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="m8 12.3 2.5 2.5L16.5 9"></path>
            </svg>
          </span>
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <SectionIntro title={valueProps.title} body={valueProps.body} align="center" />
    <div class="card-grid card-grid--three">
      {valueProps.cards.map((card) => (
        <article class={`info-card info-card--highlight info-card--${card.tone ?? 'brand'}`}>
          <span class="info-card__icon" aria-hidden="true">
            {card.tone === 'brand' && (
              <svg viewBox="0 0 24 24" role="presentation">
                <path d="M4 7h16M4 12h16M4 17h10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            )}
            {card.tone === 'field' && (
              <svg viewBox="0 0 24 24" role="presentation">
                <path d="M5 8h14M5 12h10M5 16h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                <circle cx="18" cy="12" r="2" fill="currentColor"></circle>
              </svg>
            )}
            {card.tone === 'accent' && (
              <svg viewBox="0 0 24 24" role="presentation">
                <path d="M12 4 14.5 9.5 20 12l-5.5 2.5L12 20l-2.5-5.5L4 12l5.5-2.5Z" fill="currentColor"></path>
              </svg>
            )}
          </span>
          {card.eyebrow && <p class="info-card__eyebrow">{card.eyebrow}</p>}
          <h3>{card.title}</h3>
          {card.summary && <p class="info-card__summary">{card.summary}</p>}
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section content-section--tint">
    <SectionIntro title={workflows.title} body={workflows.body} />
    <div class="workflow-grid">
      {workflows.items.map((workflow) => (
        <article class={`workflow-card workflow-card--${workflow.tone ?? 'brand'}`}>
          <div class="workflow-card__top">
            <div>
              {workflow.eyebrow && <p class="info-card__eyebrow">{workflow.eyebrow}</p>}
            </div>
            {workflow.tag && <span class="workflow-card__tag">{workflow.tag}</span>}
          </div>
          <h3>{workflow.title}</h3>
          <p class="workflow-card__benefit">{workflow.benefit}</p>
          <p>{workflow.body}</p>
          <ul class="workflow-card__list">
            {workflow.bullets.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="split-panel">
      <div>
        <SectionIntro eyebrow="Illustrative Proof" title={proof.title} body={proof.body} />
        <p class="section-note">{proof.note}</p>
      </div>

      <div class="surface-card surface-card--warm">
        <p class="surface-card__eyebrow">Why it works</p>
        <h2>Less re-entry. Less explaining. Less chasing.</h2>
        <p>When setup, signup, and weekly updates live in the same system, staff do not have to rebuild context every time something changes.</p>
      </div>
    </div>
  </section>

  <section class="content-section content-section--contrast">
    <div class="split-panel split-panel--balanced">
      <div>
        <SectionIntro eyebrow="Family Experience" title={family.title} body={family.body} />
      </div>

      <ul class="check-list">
        {family.bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <CtaBanner eyebrow={cta.eyebrow} title={cta.title} body={cta.body} primary={primaryCta} secondary={secondaryCta} />
</BaseLayout>
