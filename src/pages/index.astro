---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBanner from '../components/CtaBanner.astro';
import CtaCluster from '../components/CtaCluster.astro';
import ProgramBoard from '../components/ProgramBoard.astro';
import ProgramFlow from '../components/ProgramFlow.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { homePage, primaryCta, secondaryCta } from '../data/site';

const { hero, heroFlow, valueProps, steps, proof, family, cta } = homePage;
---

<BaseLayout title={homePage.title} description={homePage.description} pageName={homePage.pageName}>
  <section class="hero hero--home">
    <div class="hero__grid">
      <div class="hero__copy">
        <p class="hero__eyebrow">{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p class="hero__lede">{hero.body}</p>
        <CtaCluster primary={primaryCta} secondary={secondaryCta} />

        <ul class="hero__signal-list">
          <li>Built around operator workflows</li>
          <li>Structured for families to follow more easily</li>
          <li>Designed for a cleaner rollout path</li>
        </ul>
      </div>

      <div class="hero__visual-stack">
        <ProgramFlow
          eyebrow="How it comes together"
          title="Move from scattered updates to one clearer family-facing flow"
          operator={heroFlow.operator}
          hubLabel={heroFlow.hubLabel}
          hubTitle={heroFlow.hubTitle}
          hubItems={heroFlow.hubItems}
          family={heroFlow.family}
        />
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionIntro title={valueProps.title} body={valueProps.body} align="center" />
    <div class="card-grid card-grid--three">
      {valueProps.cards.map((card) => (
        <article class="info-card">
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section content-section--tint">
    <SectionIntro title={steps.title} body={steps.body} />
    <div class="step-grid">
      {steps.items.map((step, index) => (
        <article class="step-card">
          <span class="step-card__index">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="split-panel split-panel--balanced">
      <div>
        <SectionIntro eyebrow="Illustrative Proof" title={proof.title} body={proof.body} />
        <p class="section-note">{proof.note}</p>
      </div>

      <ProgramBoard label="Illustrative operator view" title={proof.boardTitle} items={proof.boardItems} note={proof.note} />
    </div>
  </section>

  <section class="content-section content-section--contrast">
    <div class="split-panel split-panel--balanced">
      <div>
        <SectionIntro eyebrow="Family Experience" title={family.title} body={family.body} />
      </div>

      <ul class="check-list">
        {family.bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <CtaBanner eyebrow={cta.eyebrow} title={cta.title} body={cta.body} primary={primaryCta} secondary={secondaryCta} />
</BaseLayout>
