---
import type { FlowGroup } from '../data/site';

interface Props {
  eyebrow: string;
  title: string;
  operator: FlowGroup;
  hubLabel: string;
  hubTitle: string;
  hubItems: string[];
  family: FlowGroup;
}

const { eyebrow, title, operator, hubLabel, hubTitle, hubItems, family } = Astro.props;
---

<aside class="journey-map" aria-label={title}>
  <p class="journey-map__eyebrow">{eyebrow}</p>
  <h3>{title}</h3>

  <div class="journey-map__grid">
    <section class="journey-map__rail">
      <p class="journey-map__label">{operator.label}</p>
      <ul class="journey-map__chips">
        {operator.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="journey-map__hub">
      <p class="journey-map__hub-label">{hubLabel}</p>
      <h4>{hubTitle}</h4>
      <ul class="journey-map__hub-list">
        {hubItems.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="journey-map__rail">
      <p class="journey-map__label">{family.label}</p>
      <ul class="journey-map__chips journey-map__chips--outcome">
        {family.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>
  </div>
</aside>