---
import CtaCluster from './CtaCluster.astro';

type Link = {
  label: string;
  href: string;
};

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  primary: Link;
  secondary?: Link;
}

const { eyebrow, title, body, primary, secondary } = Astro.props;
---

<section class="cta-banner">
  <div class="cta-banner__content">
    {eyebrow && <p class="section-intro__eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    <p>{body}</p>
    <CtaCluster primary={primary} secondary={secondary} />
  </div>
</section>
