---
const clientExample = {
  logoSrc: '/client-example-logo.png',
  name: 'Program page',
  sourceLabel: 'Base app',
  targetLabel: 'Program page',
  sourceTitle: 'HuddleWay',
  targetTitle: 'Select Basketball',
  targetBody: 'Select Basketball',
};
---

<section class="content-section brand-transition" aria-label="Branding transition example">
  <div class="brand-transition__panel">
    <div class="brand-transition__copy">
      <p class="brand-transition__body">
        Families open HuddleWay and land on your program page, with your program's name, colors,
        and identity front and center.
      </p>
    </div>

    <div class="brand-transition__stage" aria-hidden="true">
      <div class="brand-transition__glow brand-transition__glow--left"></div>
      <div class="brand-transition__glow brand-transition__glow--right"></div>

      <div class="brand-transition__rail"></div>

      <div class="brand-transition__dock brand-transition__dock--source">
        <span class="brand-transition__dock-icon">
          <img src="/logo-mark.png" alt="" />
        </span>
        <div>
          <p class="brand-transition__dock-label">{clientExample.sourceLabel}</p>
          <p class="brand-transition__dock-title">{clientExample.sourceTitle}</p>
        </div>
      </div>

      <div class="brand-transition__dock brand-transition__dock--target">
        <span class="brand-transition__dock-icon brand-transition__dock-icon--target brand-transition__dock-icon--image">
          <img src={clientExample.logoSrc} alt="" />
        </span>
        <div>
          <p class="brand-transition__dock-label">{clientExample.targetLabel}</p>
          <p class="brand-transition__dock-title">{clientExample.targetTitle}</p>
        </div>
      </div>

      <div class="brand-transition__card-wrap">
        <div class="brand-transition__card-shadow"></div>
        <div class="brand-transition__card">
          <div class="brand-transition__face brand-transition__face--source">
            <span class="brand-transition__app-icon">
              <img src="/logo-mark.png" alt="" />
            </span>
            <div class="brand-transition__app-copy">
              <p class="brand-transition__app-label">HuddleWay</p>
              <p class="brand-transition__app-title">Core app experience</p>
            </div>
          </div>

          <div class="brand-transition__face brand-transition__face--target">
            <span class="brand-transition__app-icon brand-transition__app-icon--target brand-transition__app-icon--image">
              <img src={clientExample.logoSrc} alt="" />
            </span>
            <div class="brand-transition__app-copy">
              <p class="brand-transition__app-label">{clientExample.name}</p>
              <p class="brand-transition__app-title">{clientExample.targetBody}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="brand-transition__signal brand-transition__signal--one"></div>
      <div class="brand-transition__signal brand-transition__signal--two"></div>
      <div class="brand-transition__signal brand-transition__signal--three"></div>
    </div>
  </div>
</section>

<style>
  .brand-transition {
    padding: 0.35rem 0 0.9rem;
  }

  .brand-transition__panel {
    position: relative;
    overflow: hidden;
    padding: clamp(0.75rem, 1.8vw, 1rem);
    border: 1px solid rgba(23, 31, 46, 0.08);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgba(17, 103, 242, 0.14), transparent 28%),
      radial-gradient(circle at 88% 22%, rgba(236, 106, 58, 0.12), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(240, 245, 255, 0.94));
    box-shadow: 0 20px 50px rgba(23, 31, 46, 0.08);
  }

  .brand-transition__copy {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin: 0 auto 0.45rem;
    text-align: center;
  }

  .brand-transition__body {
    margin: 0;
    font-size: clamp(0.96rem, 1.1vw, 1.04rem);
    max-width: 52rem;
    margin-inline: auto;
  }

  .brand-transition__stage {
    position: relative;
    min-height: 12.75rem;
    padding: 0 0 0.5rem;
  }

  .brand-transition__glow {
    position: absolute;
    inset: auto;
    width: 5.5rem;
    height: 5.5rem;
    border-radius: 999px;
    filter: blur(14px);
    opacity: 0.7;
  }

  .brand-transition__glow--left {
    top: 0.15rem;
    left: 8%;
    background: rgba(17, 103, 242, 0.16);
  }

  .brand-transition__glow--right {
    right: 8%;
    bottom: 0.25rem;
    background: rgba(236, 106, 58, 0.14);
  }

  .brand-transition__rail {
    position: absolute;
    left: 10%;
    right: 10%;
    top: 62%;
    height: 0.35rem;
    transform: translateY(-50%);
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(17, 103, 242, 0.18), rgba(17, 103, 242, 0.03) 36%, rgba(236, 106, 58, 0.03) 64%, rgba(236, 106, 58, 0.18));
  }

  .brand-transition__dock {
    position: absolute;
    top: 62%;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    border: 1px solid rgba(23, 31, 46, 0.08);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 24px rgba(23, 31, 46, 0.08);
    backdrop-filter: blur(14px);
  }

  .brand-transition__dock--source {
    left: 0;
    transform: translateY(-52%) rotate(-5deg);
  }

  .brand-transition__dock--target {
    right: 0;
    transform: translateY(-48%) rotate(5deg);
  }

  .brand-transition__dock-icon,
  .brand-transition__app-icon {
    display: inline-grid;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
    overflow: hidden;
    border-radius: 0.7rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.84);
  }

  .brand-transition__dock-icon img,
  .brand-transition__app-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-transition__dock-icon--image,
  .brand-transition__app-icon--image {
    width: 3rem;
    height: 3rem;
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 8px 18px rgba(23, 31, 46, 0.12);
  }

  .brand-transition__dock-icon--image img,
  .brand-transition__app-icon--image img {
    object-fit: contain;
    padding: 0;
  }

  .brand-transition__dock-icon--target,
  .brand-transition__app-icon--target {
    background:
      radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.9), transparent 28%),
      linear-gradient(135deg, #1f7de3 0%, #346ff3 46%, #f08a52 100%);
    color: white;
    box-shadow: 0 14px 28px rgba(52, 111, 243, 0.26);
  }

  .brand-transition__dock-icon--target span,
  .brand-transition__app-initials {
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: -0.06em;
  }

  .brand-transition__dock-label,
  .brand-transition__app-label {
    margin: 0;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(23, 31, 46, 0.48);
  }

  .brand-transition__dock-title,
  .brand-transition__app-title {
    margin: 0.2rem 0 0;
    color: var(--ink);
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.05;
  }

  .brand-transition__card-wrap {
    position: absolute;
    top: 62%;
    left: 8%;
    z-index: 2;
    width: min(13rem, 46vw);
    animation: brand-card-travel 7.6s cubic-bezier(0.65, 0, 0.2, 1) infinite;
  }

  .brand-transition__card-shadow {
    position: absolute;
    left: 12%;
    right: 12%;
    bottom: -0.55rem;
    height: 0.8rem;
    border-radius: 999px;
    background: rgba(14, 26, 48, 0.18);
    filter: blur(8px);
    animation: brand-shadow-drift 7.6s cubic-bezier(0.65, 0, 0.2, 1) infinite;
  }

  .brand-transition__card {
    position: relative;
    overflow: hidden;
    min-height: 5.5rem;
    border-radius: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.84);
    box-shadow: 0 18px 34px rgba(12, 22, 36, 0.14);
    backdrop-filter: blur(16px);
    animation: brand-card-rock 7.6s ease-in-out infinite;
  }

  .brand-transition__card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.66), rgba(255, 255, 255, 0.08));
    pointer-events: none;
  }

  .brand-transition__face {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem;
  }

  .brand-transition__face--source {
    animation: brand-face-source 7.6s linear infinite;
  }

  .brand-transition__face--target {
    opacity: 0;
    grid-template-columns: 3rem 1fr;
    animation: brand-face-target 7.6s linear infinite;
  }

  .brand-transition__face--target .brand-transition__app-copy {
    gap: 0.1rem;
  }

  .brand-transition__face--target .brand-transition__app-title {
    font-size: 0.92rem;
  }

  .brand-transition__app-copy {
    display: grid;
    gap: 0.15rem;
  }

  .brand-transition__signal {
    position: absolute;
    top: 62%;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: rgba(17, 103, 242, 0.28);
    transform: translateY(-50%);
  }

  .brand-transition__signal::after {
    content: '';
    position: absolute;
    inset: -0.55rem;
    border-radius: inherit;
    border: 1px solid currentColor;
    opacity: 0;
    animation: brand-signal-pulse 2.4s ease-out infinite;
  }

  .brand-transition__signal--one {
    left: 33%;
    color: rgba(17, 103, 242, 0.24);
  }

  .brand-transition__signal--two {
    left: 50%;
    width: 0.85rem;
    height: 0.85rem;
    color: rgba(52, 111, 243, 0.24);
  }

  .brand-transition__signal--three {
    right: 33%;
    background: rgba(236, 106, 58, 0.22);
    color: rgba(236, 106, 58, 0.24);
  }

  @keyframes brand-card-travel {
    0%,
    12% {
      transform: translate3d(0, -50%, 0);
    }

    42% {
      transform: translate3d(34vw, -56%, 0);
    }

    58% {
      transform: translate3d(34vw, -56%, 0);
    }

    88%,
    100% {
      transform: translate3d(calc(68vw - 100%), -48%, 0);
    }
  }

  @keyframes brand-shadow-drift {
    0%,
    12% {
      transform: scaleX(0.88);
      opacity: 0.24;
    }

    42%,
    58% {
      transform: scaleX(0.98);
      opacity: 0.2;
    }

    88%,
    100% {
      transform: scaleX(0.84);
      opacity: 0.18;
    }
  }

  @keyframes brand-card-rock {
    0%,
    100% {
      transform: rotate(-10deg) translateY(0);
    }

    24% {
      transform: rotate(-7deg) translateY(-0.6rem);
    }

    50% {
      transform: rotate(0deg) translateY(-0.85rem);
    }

    74% {
      transform: rotate(8deg) translateY(-0.35rem);
    }
  }

  @keyframes brand-face-source {
    0%,
    40% {
      opacity: 1;
    }

    52%,
    100% {
      opacity: 0;
    }
  }

  @keyframes brand-face-target {
    0%,
    46% {
      opacity: 0;
    }

    58%,
    100% {
      opacity: 1;
    }
  }

  @keyframes brand-signal-pulse {
    0% {
      transform: scale(0.65);
      opacity: 0;
    }

    30% {
      opacity: 0.45;
    }

    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  @media (max-width: 960px) {
    .brand-transition__stage {
      min-height: 11.5rem;
    }

    .brand-transition__dock {
      gap: 0.45rem;
      padding: 0.48rem 0.58rem;
    }

    .brand-transition__dock-title,
    .brand-transition__app-title {
      font-size: 0.72rem;
    }

    .brand-transition__dock-icon--image,
    .brand-transition__app-icon--image {
      width: 2.65rem;
      height: 2.65rem;
    }

    .brand-transition__card-wrap {
      width: min(12rem, 48vw);
    }

    @keyframes brand-card-travel {
      0%,
      12% {
        transform: translate3d(0, -50%, 0);
      }

      42% {
        transform: translate3d(28vw, -56%, 0);
      }

      58% {
        transform: translate3d(28vw, -56%, 0);
      }

      88%,
      100% {
        transform: translate3d(calc(56vw - 100%), -48%, 0);
      }
    }
  }

  @media (max-width: 720px) {
    .brand-transition {
      padding: 0.15rem 0 0.7rem;
    }

    .brand-transition__panel {
      border-radius: 1.5rem;
      padding: 0.8rem;
    }

    .brand-transition__copy {
      margin-bottom: 0.45rem;
    }

    .brand-transition__stage {
      min-height: 11.75rem;
      padding-top: 0.1rem;
    }

    .brand-transition__rail {
      left: 1.15rem;
      right: 1.15rem;
      top: auto;
      bottom: 1.55rem;
      transform: none;
    }

    .brand-transition__dock {
      top: auto;
      bottom: 0;
      transform: none;
      width: calc(50% - 0.4rem);
      padding: 0.45rem;
      border-radius: 0.85rem;
    }

    .brand-transition__dock--source {
      left: 0;
    }

    .brand-transition__dock--target {
      right: 0;
    }

    .brand-transition__dock-title,
    .brand-transition__app-title {
      font-size: 0.68rem;
    }

    .brand-transition__dock-label,
    .brand-transition__app-label {
      font-size: 0.52rem;
    }

    .brand-transition__dock-icon,
    .brand-transition__app-icon {
      width: 1.95rem;
      height: 1.95rem;
      border-radius: 0.62rem;
    }

    .brand-transition__dock-icon--image,
    .brand-transition__app-icon--image {
      width: 2.3rem;
      height: 2.3rem;
      border-radius: 0.72rem;
    }

    .brand-transition__card-wrap {
      top: 1.25rem;
      left: 0.25rem;
      width: min(10.8rem, calc(100% - 1.8rem));
    }

    .brand-transition__card {
      min-height: 4.95rem;
      border-radius: 1rem;
    }

    .brand-transition__face {
      gap: 0.45rem;
      padding: 0.58rem;
    }

    .brand-transition__face--target {
      grid-template-columns: 2.3rem 1fr;
    }

    .brand-transition__face--target .brand-transition__app-title {
      font-size: 0.78rem;
    }

    .brand-transition__signal {
      top: auto;
      bottom: 1.4rem;
      transform: none;
    }

    .brand-transition__signal--one {
      left: 24%;
    }

    .brand-transition__signal--two {
      left: calc(50% - 0.5rem);
    }

    .brand-transition__signal--three {
      right: 24%;
    }

    @keyframes brand-card-travel {
      0%,
      12% {
        left: 0.25rem;
        transform: translate3d(0, 0, 0);
      }

      42% {
        left: calc(50% - 5.4rem);
        transform: translate3d(0, 0.4rem, 0);
      }

      58% {
        left: calc(50% - 5.4rem);
        transform: translate3d(0, 0.4rem, 0);
      }

      88%,
      100% {
        left: calc(100% - min(10.8rem, calc(100% - 1.8rem)) - 0.5rem);
        transform: translate3d(0, 0, 0);
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-transition__card-wrap,
    .brand-transition__card,
    .brand-transition__card-shadow,
    .brand-transition__face,
    .brand-transition__signal::after {
      animation: none;
    }

    .brand-transition__card-wrap {
      top: 58%;
      left: auto;
      right: 5rem;
      transform: translateY(-50%);
    }

    .brand-transition__face--source {
      opacity: 0;
    }

    .brand-transition__face--target {
      opacity: 1;
    }

    @media (max-width: 720px) {
      .brand-transition__card-wrap {
        top: 1.25rem;
        right: 0.5rem;
        transform: none;
      }
    }
  }
</style>
