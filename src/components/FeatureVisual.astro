---
import type { FeatureLane } from '../data/site';

interface Props {
  badge: string;
  title: string;
  lanes: FeatureLane[];
}

const { badge, title, lanes } = Astro.props;
---

<aside class="capability-visual" aria-label={title}>
  <div class="capability-visual__header">
    <span class="capability-visual__badge">{badge}</span>
    <div>
      <p class="capability-visual__eyebrow">Capability view</p>
      <h3>{title}</h3>
    </div>
  </div>

  <div class="capability-visual__lanes">
    {lanes.map((lane) => (
      <section class="capability-visual__lane">
        <p class="capability-visual__label">{lane.label}</p>
        <ul class="surface-list surface-list--compact">
          {lane.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</aside>