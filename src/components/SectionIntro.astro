---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, body, align = 'left' } = Astro.props;
---

<header class={`section-intro section-intro--${align}`}>
  {eyebrow && <p class="section-intro__eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {body && <p class="section-intro__body">{body}</p>}
</header>
