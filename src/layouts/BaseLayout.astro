---
import '../styles/global.css';
import { navigation, primaryCta, siteMeta } from '../data/site';

interface Props {
  title: string;
  description: string;
  pageName?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, pageName = 'default', structuredData } = Astro.props;
const pathname = Astro.url.pathname;
const toStaticFile = (value: string) => {
  const [pathOnly] = value.split('#');

  if (pathOnly === '' || pathOnly === '/') {
    return 'index.html';
  }

  if (pathOnly.endsWith('.html')) {
    return pathOnly.replace(/^\//, '');
  }

  return `${pathOnly.replace(/^\/+|\/+$/g, '')}.html`;
};

const homeHref = navigation[0]?.href ?? 'index.html';
const currentFile = toStaticFile(pathname);
const siteUrl = Astro.site ?? new URL('https://huddleway.com');
const normalizedPathname = (() => {
  if (pathname === '/index.html' || pathname === '/') {
    return '/';
  }

  const withoutIndex = pathname.replace(/\/index\.html$/, '/');
  const withoutHtml = withoutIndex.replace(/\.html$/, '');
  const withoutTrailingSlash = withoutHtml !== '/' ? withoutHtml.replace(/\/$/, '') : withoutHtml;

  return withoutTrailingSlash || '/';
})();
const canonicalUrl = new URL(normalizedPathname, siteUrl).toString();
const schemaItems: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteMeta.name,
    url: siteUrl.toString(),
    description: siteMeta.description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: siteMeta.name,
    url: siteUrl.toString(),
  },
];

if (structuredData) {
  schemaItems.push(...(Array.isArray(structuredData) ? structuredData : [structuredData]));
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" sizes="any" type="image/png" />
    <link rel="shortcut icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {schemaItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body class={`page page--${pageName}`}>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href={homeHref}>
            <span class="brand__mark" aria-hidden="true"><img src="/logo-mark.png" alt="" /></span>
            <span class="brand__text">{siteMeta.name}</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {navigation.map((item) => {
              const active = toStaticFile(item.href) === currentFile;

              return (
                <a class={`site-nav__link ${active ? 'is-active' : ''}`} href={item.href} aria-current={active ? 'page' : undefined}>
                  {item.label}
                </a>
              );
            })}
          </nav>

          <a class="button button--primary site-header__cta" href={primaryCta.href}>{primaryCta.label}</a>
        </div>
      </header>

      <main id="main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__grid">
          <div>
            <a class="brand brand--footer" href={homeHref}>
              <span class="brand__mark" aria-hidden="true"><img src="/logo-mark.png" alt="" /></span>
              <span class="brand__text">{siteMeta.name}</span>
            </a>
            <p class="site-footer__blurb">{siteMeta.footerBlurb}</p>
          </div>

          <div>
            <h2 class="site-footer__heading">Pages</h2>
            <ul class="site-footer__list">
              {navigation.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="site-footer__heading">Get Started</h2>
            <p class="site-footer__note">Start with setup, then see how HuddleWay gives families one clear app and admins one simple system.</p>
            <a class="button button--primary button--full" href={primaryCta.href}>{primaryCta.label}</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
