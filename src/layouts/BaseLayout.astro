---
import '../styles/global.css';
import { navigation, primaryCta, siteMeta } from '../data/site';

interface Props {
  title: string;
  description: string;
  pageName?: string;
}

const { title, description, pageName = 'default' } = Astro.props;
const pathname = Astro.url.pathname;
const homeHref = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class={`page page--${pageName}`}>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href={homeHref}>
            <span class="brand__mark">M</span>
            <span class="brand__text">{siteMeta.name}</span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            {navigation.map((item) => {
              const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));

              return (
                <a class={`site-nav__link ${active ? 'is-active' : ''}`} href={item.href} aria-current={active ? 'page' : undefined}>
                  {item.label}
                </a>
              );
            })}
          </nav>

          <a class="button button--primary site-header__cta" href={primaryCta.href}>{primaryCta.label}</a>
        </div>
      </header>

      <main id="main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__grid">
          <div>
            <a class="brand brand--footer" href={homeHref}>
              <span class="brand__mark">M</span>
              <span class="brand__text">{siteMeta.name}</span>
            </a>
            <p class="site-footer__blurb">{siteMeta.footerBlurb}</p>
          </div>

          <div>
            <h2 class="site-footer__heading">Pages</h2>
            <ul class="site-footer__list">
              {navigation.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="site-footer__heading">Get Started</h2>
            <p class="site-footer__note">Start with setup expectations, then explore how MyTeam can create a clearer experience for families and staff.</p>
            <a class="button button--primary button--full" href={primaryCta.href}>{primaryCta.label}</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
